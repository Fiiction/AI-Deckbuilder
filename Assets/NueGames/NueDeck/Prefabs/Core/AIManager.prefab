    _serialized: 1
  initialPrompt: "We are simulating a deckbuilding card game like Slay the Spire.
    \r\nI will give you informations of a card usage, and request you to reply with
    what's the consequence of the action. Also, I will need you to help me with prompts
    of Stable Diffusion image generation for characters and cards.\r\nThe protagonist
    is ##HeroName##, who is ##HeroDesc##. Please help me with a brief background
    story (within 50 words) and prompts for image generation of the hero. If it comes
    from an existing fictional work (game, comic, etc.), refer to the original work's
    setting.\nThe prompt for image generation should include the characters' appearance,
    outfit, and the art style of original work, etc.. The prompt should cover the
    hero's feature from head to feet, to make the image generation model more likely
    to produce a full-body portrait.\r\r\nPlease reply with following json structure:
    (example is a reply for the character Hanzo from Overwatch) Please DO NOT repeat
    any json structure I provided.\r\n{\r\n\t\"backgroundStory\": \"Mastering his
    skills as a bowman and an assassin, Hanzo Shimada strives to prove himself as
    a warrior without peer. He has a cynical view on the nature of the world, and
    believes that compassion has no place in battle\",\r\n\t\"prompt\": \"Hanzo,
    1 man, archer, Japanese, Traditional Japanese Outfit, holding a bow, Character
    from Overwatch, \"\r\n}"
  startGamePrompt: 'Now player as ##HeroName##, ##HeroDesc##, enters a fight.

    There
    are ##EnemyCnt## enemy(s):


    ##EnemyDescs##'
  jsonCorrectionPrompt: "Error occured parsing your reply in json format. Please
    make sure you reply with one single Json structure, without any other information.
    \n"
  gameStartPending: 0
  levelCnt: 0
  startGameMsgCnt: -1
  startTurnMsgCnt: -1
  cardGenMessageMerged: -1
