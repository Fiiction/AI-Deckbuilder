--- !u!114 &6549583421798582084
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 245239240643104206}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: db81833cc9a238a4b93475a910009467, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  prompt1_withTarget: "The player, as ##PlayerName## ##PlayerCustomStatus##, using
    following card:\r\n\r\n##CardName##: ##CardDesc##, spending ##ManaSpent## mana\r\n\rtargeting
    following enemy character: ##EnemyName##, who is ##EnemyDesc####EnemyCustomStatus##.\r\n\r\nWhat
    will happen? Please consider the card used in the past. Describe with natural
    language within 20 words.\r\n\r\nThen answer with following structure, what will
    be the effect(s) of this card?\r\n##Specific##\r\n\r\r\nPlease reply with one
    single json format:\r\n{\r\n\t\"effects\": [\"Deal Damage\", \"Deal Damage\",
    \"Draw\", \"Steal Life\"]\r\n}"
  prompt1_noTarget: "The player, as ##PlayerName## ##PlayerCustomStatus##, using
    following card:\r\n\r\n##CardName##: ##CardDesc##, spending ##ManaSpent## mana\r\n\r\n\r\nWhat
    will happen? Please consider the card used in the past. Describe with natural
    language within 20 words.\r\n\r\nThen answer with following structure, what will
    be the effect(s) of this card?\r\n##Specific##\r\n\r\r\nPlease reply with one
    single json format:\r\n{\r\n\t\"effects\": [\"Deal Damage\", \"Deal Damage\",
    \"Draw\", \"Steal Life\"]\r\n}\n"
  prompt2: "Now answer with following structure, what will be the effect(s) of this
    card?\r\n\r##Specific##\r\n\nPlease reply with one single json format:\r\n{\r\n\t\"effects\":
    [\"Deal Damage\", \"Deal Damage\", \"Draw\", \"Steal Life\"]\r\n}"
  prompt_specific: "\nThe effect(s) can be one or more chosen from follow types:\r\n\r\n-
    Deal Damage: Deal damage to target\r\n- Heal: Heal target\r\n- Add Block: Add
    stacks of block, blocking same amount of upcoming damage\r\r\n- Draw: draw cards\r\n-
    Gain Mana: gain mana to do more actions in this turn\r\n- Steal Life: steal life
    from the target like a vampire\r\n- Stun: stunning the object, prevent it to
    move in following rounds\r\n- Destroy the Card: destroying the card used permanently\r\n-
    Add Custom Status: add/remove custom buff or debuff to object. Please store any
    effects that need to be checked out in the future as custom status\n\nThe object
    of each of these effects can be the user, the targeted enemy or all enemies,
    which will be chosen later.\nYou can choose one same effect 2 or more times,
    if it's dealt on different objects, or casting 2 different custom effect at the
    same time.\r\n\r"
  prompt3_Normal: "For the ##No## effect \"##EffectName##\", what's the target and
    the numeric value of this effect:\r\n\r\nPlease reply with following json format:
    (content in parentheses are comments)\r\n{\r\n\t\"target\": \"self\", (or \"targetEnemy\"
    or \"AllEnemies\")\r\n\t\"value\": 3 (indicates ##ValueMeaning##) \r\n}"
  prompt3_CustomEffect: "For the ##No## effect \"Add Custom Status\", what's the
    name of status, the target and the numeric value of this effect:\r\n\r\nPlease
    reply with following json format: (content in parentheses are comments)\r\n{\r\n\t\"buffname\":
    \"focus\", (the name of the buff or debuff, e.g. \"burn\", \"toxic\", \"charge\",
    etc.)\r\n\t\"target\": \"self\", (or \"targetEnemy\" or \"allEnemies\")\r\n\t\"value\":
    3 (indicates how many stacks of this status are casted on target. Minus value
    to clear) \r\n}\r\n"
  prompt_StartTurn1: "Now player, ##PlayerDesc## ##PlayerCustomStatus##, starts a
    new turn.\r\nAccording the custom status they have and cards they played, will
    there be effects at the start of the turn?\r\nPlease reply with one single json
    format:\r\n{\r\n\t\"effects\": [\"Deal Damage\",  \"Draw\", \"Gain Mana\"]\r\n}\r\nif
    there won't be turn-start effects, reply with:\r\n{\r\n\t\"effects\": []\r\n}"
  prompt_EnemyTurn1: "Now an enemy, ##EnemyName##, ##EnemyDesc## ##EnemyCustomStatus##
    takes its turn.\r\nIt want to perform an action, ##EnemyActionName##, ##EnemyActionDesc##.\r\nWhat
    will be the effects of their status and actions?\r\n\r\nThe effect(s) can be
    one or more chosen from follow types:\r\n\r\n- Deal Damage: Deal damage to the
    or the enemy itself.\r\n- Heal: Heal someone.\r\n- Add Block: Add stacks of block,
    blocking same amount of upcoming damage.\r\n- Add Custom Status: add custom buff
    or debuff to object. Please store any effects that need to be checked out in
    the future as custom status\r\n\r\nPlease reply with following json format:\r\n{\r\n\t\"effects\":
    [\"Deal Damage\",  \"Add Custom Status\"]\r\n}\r"
  prompt3_Normal_Enemy: "For the effect \"##EffectName##\", what's the target and
    the numeric value of this effect:\r\n\r\nPlease reply with following json format:
    (content in parentheses are comments)\r\n{\r\n\t\"target\": \"hero\", (or \"enemySelf\"
    or \"allEnemies\")\r\n\t\"value\": 3 (indicates ##ValueMeaning##) \r\n}"
  prompt3_CustomEffect_Enemy: "For the effect \"Add Custom Status\", what's the name
    of status, the target and the numeric value of this effect:\r\n\r\n\r\nPlease
    reply with following json format: (content in parentheses are comments)\r\n{\r\n\t\"buffname\":
    \"poison\", (the name of the buff or debuff, e.g. \"burn\", \"toxic\", \"charge\",
    etc.)\r\n\t\"target\": \"hero\", (or \"enemySelf\" or \"allEnemies\")\r\n\t\"value\":
    3 (indicates how many stacks of this status are casted on target) \r\n}\r\n"
  processingCanvas: {fileID: 1978969409886390374}
  actionDatas: []
  cardsUsedInBattle: 0
