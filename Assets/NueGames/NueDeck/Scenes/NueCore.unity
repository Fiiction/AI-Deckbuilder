  m_Script: {fileID: 11500000, guid: acec668d880580a45872d7300b77d6a7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  deepseekParams:
    apiKey: sk-7bf38df2ed1245ce9dfd5ab62346449c
    temperature: 1
    role: 
    timeout: 0
    throttle: 0
    _serialized: 1
  initialPrompt: "We are simulating a deckbuilding card game like Slay the Spire.
    \r\nI will give you informations of a card usage, and request you to reply with
    what's the consequence of the action.\nPlease reply with \"I understand.\""
  startGamePrompt: 'Now player enters a fight.

    Player can spend 3 manas to use
    cards on each turn. Cards represent protagonist''s actions.

    Most cards cost
    1 mana. Very powerful moves will cost 2 or 3 mana. 0-mana cards represent swift
    but weaker moves.

    The effects of a card include dealing damage to target,
    healing the user, adding tacks of "block" (blocking same amount of upcoming damage),
    applying buff to user or casting debuff to targets.

    Typically, one cost
    cards are worth 5 damage, or 5 stacks of block, or 3 stacks of buff/debuff. Cards
    with higher rarity can be stronger.

    Please reply with "I understand."'
