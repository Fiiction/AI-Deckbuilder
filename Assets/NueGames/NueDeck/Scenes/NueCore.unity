--- !u!114 &551255184
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 551255182}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: db81833cc9a238a4b93475a910009467, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  prompt1_withTarget: 'The player,who is ##PlayerDesc####PlayerCustomStatus##, using
    following card:



    ##CardName##: ##CardDesc##, spending ##ManaSpent## mana



    targeting
    following enemy character: ##EnemyName##, who is ##EnemyDesc####EnemyCustomStatus##



    What
    will happen? please describe with natural language within 20 words.'
  prompt1_noTarget: 'The player,who is ##PlayerDesc####PlayerCustomStatus##, using
    following card:



    ##CardName##: ##CardDesc##, spending ##ManaSpent## mana



    What
    will happen? please describe with natural language within 20 words.'
  prompt2: "Now answer with following structure, what will be the effect(s) of this
    card?\r\n\r\nThe effect(s) can be one or more chosen from follow types:\r\n\r\n-
    Deal Damage: Deal damage to target\r\n- Heal: Heal target\r\n- Add Block: Add
    stacks of block, blocking same amount of upcoming damage\r\r\n- Draw: draw cards\r\n-
    Gain Mana: gain mana to do more actions in this turn\r\n- Steal Life: steal life
    from the target like a vampire\r\n- Stun: stunning the object, prevent it to
    move in following rounds\r\n- Destroy the Card: destroying the card used permanently\r\n-
    Add Custom Status: add custom buff or debuff to object\r\n\r\nThe object of each
    of these effects can be the user, the targeted enemy or all enemies, which will
    be chosen later.\r\n\r\nPlease reply with following json format:\r\n{\r\n\t\"effects\":
    [\"Deal Damage\", \"Draw\", \"Steal Life\"]\r\n}"
  prompt3_Normal: "For the effect \"##EffectName##\", what's the target and the numeric
    value of this effect:\r\n\r\nPlease reply with following json format: (content
    in parentheses are comments)\r\n{\r\n\t\"target\": \"self\", (or \"targetEnemy\"
    or \"AllEnemies\")\r\n\t\"value\": 3 (indicates ##ValueMeaning##) \r\n}"
  prompt3_CustomEffect: "For the effect \"Add Custom Status\", what's the name of
    status, the target and the numeric value of this effect:\r\n\r\nPlease reply
    with following json format: (content in parentheses are comments)\r\n{\r\n\t\"buffname\":
    \"focus\", (the name of the buff or debuff, e.g. \"burn\", \"toxic\", \"charge\",
    etc.)\r\n\t\"target\": \"self\", (or \"targetEnemy\" or \"allEnemies\")\r\n\t\"value\":
    3 (indicates how many stacks of this status are casted on target) \r\n}\r\n"
  cardName: 
  cardDesc: 
  userName: 
  userDesc: 
  targetName: 
  targetDesc: 
  userStatusStr: 
  targetStatusStr: 
  prompt1Sent: 
  actionDatas: []
